# ── Public website — build-time config ──────────────────────────────────────
# Copy to  website/.env.production  on the VPS (or pass inline before the build:
#   REACT_APP_API_URL=https://admin.sandhyagrand.in npm run build )
#
# This value is BAKED INTO the static bundle, so you must rebuild the website
# whenever it changes. It points every /api and /uploads call from the public
# site at the admin/API origin.
REACT_APP_API_URL=https://admin.sandhyagrand.in
