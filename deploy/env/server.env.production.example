# ── Sandhya Grand API — PRODUCTION environment ──────────────────────────────
# Copy this to  server/.env  on the VPS and fill in every blank. Most secrets
# already exist in your current dev server/.env — carry the same values over.
# Never commit the real .env (it is git-ignored).

NODE_ENV=production
PORT=5002

# MongoDB Atlas — same connection string you use in dev.
#   ⚠ Add the VPS public IP to Atlas → Network Access → IP Access List,
#     otherwise the server cannot connect.
MONGODB_URI=

# 64+ char random secret. Keep it STABLE across restarts — changing it logs
# every active session out. (Leave ENABLE_JWT_ROTATION unset to avoid that.)
JWT_SECRET=

# CORS allowlist: the public site origin(s) that call this API cross-origin.
# The admin SPA is same-origin so it technically doesn't need listing; included
# for safety. In production an empty/omitted list blocks all browser origins.
ALLOWED_ORIGINS=https://sandhyagrand.in,https://www.sandhyagrand.in,https://admin.sandhyagrand.in

# Behind nginx: trust exactly one proxy hop so req.ip, rate-limiting and the
# HTTPS/secure-cookie detection work correctly.
TRUST_PROXY=1

# API docs (/api/docs) stay OFF in production unless you flip this to true.
# ENABLE_API_DOCS=false

# Uploads and logs live on the VPS disk. Defaults are relative to server/.
UPLOAD_DIR=uploads
LOG_DIR=logs

# ── Carry these over from your existing dev server/.env ─────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
EMAIL_USER=
EMAIL_PASSWORD=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMS_PROVIDER=fast2sms
FAST2SMS_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
SUREPASS_TOKEN=
SUREPASS_BASE_URL=https://kyc-api.surepass.io
